[debug] [2026-04-19T22:06:03.100Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/temptedchat/rulesets {"name":"projects/temptedchat/rulesets/643ecec5-c45f-4983-a3c8-eeb11a6737d7","source":{"files":[{"content":"rules_version = '2';\r\nservice firebase.storage {\r\n  match /b/{bucket}/o {\r\n    match /chatUploads/{roomId}/{userId}/{fileName} {\r\n      allow read: if request.auth != null;\r\n\r\n      allow write: if request.auth != null\r\n        && request.auth.uid == userId\r\n        && request.resource.size < 10 * 1024 * 1024\r\n        && (\r\n          request.resource.contentType.matches('application/octet-stream')\r\n          || request.resource.contentType.matches('image/.*')\r\n        );\r\n\r\n      allow delete: if request.auth != null && request.auth.uid == userId;\r\n    }\r\n\r\n    match /feedback/{userId}/{fileName} {\r\n      allow read: if request.auth != null;\r\n\r\n      allow write: if request.auth != null\r\n        && request.auth.uid == userId\r\n        && request.resource.size < 5 * 1024 * 1024\r\n        && request.resource.contentType.matches('image/.*');\r\n    }\r\n\r\n    match /demoVideos/{fileName} {\r\n      allow read: if request.auth != null;\r\n\r\n      allow write: if request.auth != null\r\n        && request.resource.size < 100 * 1024 * 1024;\r\n\r\n      allow delete: if request.auth != null;\r\n    }\r\n\r\n    match /{allPaths=**} {\r\n      allow read, write: if false;\r\n    }\r\n  }\r\n}\r\n","name":"storage.rules"}]},"createTime":"2026-04-19T22:06:01.123343Z","metadata":{"services":["firebase.storage"]}}
